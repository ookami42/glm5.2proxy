{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--executable-path", "/snap/bin/chromium"],
      "env": {
        "PLAYWRIGHT_MCP_EXECUTABLE_PATH": "/usr/bin/chromium-browser"
      },
      "enabled": true
    }
  }
}
